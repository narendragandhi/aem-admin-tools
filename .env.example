# CXForge Admin Tools - Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
SERVER_PORT=10004

# Database Configuration
# Default: H2 in-memory (development)
# For PostgreSQL (production), uncomment and configure:
# DATABASE_URL=jdbc:postgresql://localhost:5432/admintools
# DATABASE_DRIVER=org.postgresql.Driver
# DATABASE_USERNAME=admintools
# DATABASE_PASSWORD=changeme
# JPA_DDL_AUTO=validate
# H2_CONSOLE_ENABLED=false

# AEM Connection
AEM_ENABLED=true
AEM_AUTHOR_URL=http://localhost:4502
AEM_PUBLISH_URL=http://localhost:4503
AEM_USERNAME=admin
# REQUIRED: Set a strong password (min 8 characters)
AEM_PASSWORD=your-secure-aem-password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:8081

# LLM Configuration
LLM_ENABLED=true
LLM_PROVIDER=ollama

# Ollama (default - local)
LLM_OLLAMA_URL=http://localhost:11434
LLM_OLLAMA_MODEL=llama3.2

# OpenAI (optional - set provider to 'openai' to use)
LLM_OPENAI_API_KEY=
LLM_OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional - set provider to 'anthropic' to use)
LLM_ANTHROPIC_API_KEY=
LLM_ANTHROPIC_MODEL=claude-3-haiku-20240307

# Job Configuration
JOBS_MAX_CONCURRENT=3
JOBS_HISTORY_RETENTION_HOURS=24

# Logging
LOG_LEVEL=INFO
ROOT_LOG_LEVEL=WARN

# Security (set to true for production)
SECURITY_ENABLED=false
SECURITY_ADMIN_USERNAME=admin
# REQUIRED when SECURITY_ENABLED=true: Set a strong password (min 8 characters)
SECURITY_ADMIN_PASSWORD=your-secure-admin-password
